# ─────────────────────────────────────────────────────────────
# Amplo environment configuration
# Copy this file to `.env.local` and fill in what you have.
# The app runs WITHOUT any keys — it falls back to a built-in
# demo generator so you can click through the whole product.
# Add keys to switch on the real AI + integrations.
# ─────────────────────────────────────────────────────────────

# Anthropic (Claude) — powers the AI content, review, and SEO agents.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model used by the agents (safe default shown).
AMPLO_MODEL=claude-sonnet-5

# ── Integrations (optional — stubs are provided) ──────────────
# Google Business Profile (reviews + local posts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connect/google/callback

# Meta (Instagram + Facebook publishing)
META_APP_ID=
META_APP_SECRET=

# Billing (Stripe) — subscription + usage-based metering
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
