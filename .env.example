# ─────────────────────────────────────────────────────────────
# Popd environment configuration
# Copy this file to `.env.local` and fill in what you have.
# The app runs WITHOUT any keys — it falls back to a built-in
# demo generator so you can click through the whole product.
# Add keys to switch on the real AI + integrations.
# ─────────────────────────────────────────────────────────────

# Google Gemini — powers the AI content, review, SEO, and image agents.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Models used by the agents (safe defaults shown). Bump the image model to
# gemini-3.1-flash-image ("Nano Banana 2") once you want the newer visuals.
POPD_TEXT_MODEL=gemini-2.5-flash
POPD_IMAGE_MODEL=gemini-2.5-flash-image

# ── Integrations (optional — stubs are provided) ──────────────
# Google Business Profile (reviews + local posts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connect/google/callback

# Meta (Instagram + Facebook publishing)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/connect/meta/callback

# Billing (Stripe) — subscription + usage-based metering
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs per plan + cadence (create products in Stripe, paste ids here)
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Autopilot cron — protect /api/cron/tick (leave blank to run open locally)
CRON_SECRET=

# Database (Supabase / Postgres) — permanent storage for accounts, brands,
# content, and subscriptions. Without it, the app uses a local file store (dev).
# Use Supabase's "Transaction pooler" connection string (port 6543).
DATABASE_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
